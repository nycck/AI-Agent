# OfficeHeart AI-assistent draait op een GRATIS lokaal model via Ollama.
# Deze instellingen zijn optioneel — zonder .env.local worden de standaarden gebruikt.

# Adres waarop Ollama draait (standaard goed).
OLLAMA_URL=http://localhost:11434

# Welk model gebruikt wordt. Opties (haal op met 'ollama pull <naam>'):
#   qwen2.5:7b     -> beste Nederlands, draait deels op CPU (paar woorden/sec)
#   llama3.2:3b    -> sneller, volledig op je GPU, iets minder kwaliteit
OLLAMA_MODEL=qwen2.5:7b
